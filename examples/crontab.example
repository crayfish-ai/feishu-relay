# Crontab 示例 - 使用 feishu-relay

# 编辑系统 crontab
# crontab -e

# ============================================
# 系统监控类
# ============================================

# 每5分钟检查磁盘空间
*/5 * * * * /opt/feishu-notifier/bin/notify "💾 磁盘状态" "$(df -h / | awk 'NR==2 {print \"使用率: \"$5}')"

# 每小时报告系统负载
0 * * * * /opt/feishu-notifier/bin/notify "📊 系统负载" "$(uptime | awk -F'load average:' '{print $2}')"

# ============================================
# 定时任务类
# ============================================

# 每天凌晨2点备份并通知
0 2 * * * /opt/backup.sh && /opt/feishu-notifier/bin/notify "✅ 备份完成" "每日备份成功"

# 每天早9点日报提醒
0 9 * * 1-5 /opt/feishu-notifier/bin/notify "📋 日报提醒" "记得填写今日工作日报"

# ============================================
# 生活提醒类
# ============================================

# 每天晚上11点提醒睡觉
0 23 * * * /opt/feishu-notifier/bin/notify "⏰ 该休息了" "早点睡觉，保持健康"

# 每周五下午6点周末提醒
0 18 * * 5 /opt/feishu-notifier/bin/notify "🎉 周末愉快" "一周辛苦了，好好休息"

# ============================================
# 重要提示
# ============================================
# 
# ⚠️ 使用系统 crontab，不是 OpenClaw cron
# 
# 正确: crontab -e
# 错误: openclaw cron create
#
# 原因:
# - 系统 crontab 是 Linux 标准定时任务
# - feishu-relay 是独立服务，不依赖 OpenClaw
# - 这样设计更可靠，符合"统一通知中心"原则
#
# ============================================
