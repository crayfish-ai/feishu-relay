#!/bin/bash
# Feishu Relay 自动注入器
# 自动为新安装的 skill 添加通知支持

FEISHU_NOTIFIER_DIR="/opt/feishu-notifier"
SKILL_DIRS=(
    "/opt/openclaw/skills"
    "$HOME/.openclaw/skills"
    "/root/.openclaw/workspace/skills"
)

# 创建通用的 notify 函数，skill 可以直接调用
create_skill_notify_wrapper() {
    local skill_dir="$1"
    local skill_name=$(basename "$skill_dir")
    
    # 创建 skill 专用的 notify 脚本
    local notify_script="$skill_dir/notify"
    
    cat > "$notify_script" << EOF
#!/bin/bash
# $skill_name 的通知脚本（自动生成）
# 发送通知到 feishu-relay

/opt/feishu-notifier/bin/notify "[$skill_name] \${1:-通知}" "\${2:-}"
EOF
    chmod +x "$notify_script"
    
    echo "✓ 为 $skill_name 创建 notify 脚本"
}

# 扫描新安装的 skill
scan_new_skills() {
    echo "=== 扫描 skill 目录 ==="
    
    for base_dir in "${SKILL_DIRS[@]}"; do
        [ -d "$base_dir" ] || continue
        
        # 遍历所有 skill
        for skill_dir in "$base_dir"/*; do
            [ -d "$skill_dir" ] || continue
            
            skill_name=$(basename "$skill_dir")
            notify_script="$skill_dir/notify"
            
            # 如果还没有 notify 脚本，创建一个
            if [ ! -f "$notify_script" ]; then
                create_skill_notify_wrapper "$skill_dir"
            fi
        done
    done
}

# 主逻辑
case "$1" in
    scan)
        scan_new_skills
        ;;
    setup)
        # 为指定 skill 创建高级集成
        skill_name="$2"
        [ -z "$skill_name" ] && { echo "用法: $0 setup <skill-name>"; exit 1; }
        
        # 查找 skill 目录
        for base_dir in "${SKILL_DIRS[@]}"; do
            if [ -d "$base_dir/$skill_name" ]; then
                create_skill_notify_wrapper "$base_dir/$skill_name"
                
                # 创建 SKILL.md 使用说明追加
                skill_md="$base_dir/$skill_name/SKILL.md"
                if [ -f "$skill_md" ] && ! grep -q "feishu-relay" "$skill_md"; then
                    cat >> "$skill_md" <> EOF

## 通知集成

本 skill 已集成 feishu-relay 统一通知系统。

### 使用方法

在 skill 脚本中发送通知：

\`\`\`bash
# 方式1: 使用 notify 命令（推荐）
./notify "标题" "内容"

# 方式2: 直接调用 feishu-relay
/opt/feishu-notifier/bin/notify "标题" "内容"

# 方式3: 定时通知
/opt/feishu-notifier/bin/feishu-task-v2 in 30 "30分钟后提醒"
\`\`\`

通知将通过 feishu-relay 统一队列发送。
EOF
                    echo "✓ 更新 $skill_name/SKILL.md"
                fi
                break
            fi
        done
        ;;
    *)
        echo "用法:"
        echo "  $0 scan          # 扫描所有 skill 并自动添加 notify"
        echo "  $0 setup <name>  # 为指定 skill 添加完整集成"
        ;;
esac
