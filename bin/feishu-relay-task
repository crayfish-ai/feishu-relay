#!/bin/bash
# feishu-relay-task v1 - 基于 cron 的简单实现
# 特点：稳定可靠，兼容性好

TASK_DIR="/opt/feishu-notifier/tasks"
CRON_TAG="# feishu-relay-task"

# 初始化
init() {
    mkdir -p "$TASK_DIR"
}

# 生成任务 ID
generate_id() {
    echo "$(date +%s)_$RANDOM"
}

# 添加一次性任务（使用 at，但指定输出到 /dev/null）
add_once() {
    local minutes="$1"
    local title="$2"
    local content="${3:-$2}"
    local id=$(generate_id)
    
    # 创建任务脚本
    local script="$TASK_DIR/task_$id.sh"
    cat > "$script" << EOF
#!/bin/bash
# $CRON_TAG
/opt/feishu-notifier/bin/notify '$title' '$content'
rm -f "$script"
EOF
    chmod +x "$script"
    
    # 使用 at，但禁用邮件通知
    echo "$script" | at -M now + $minutes minutes 2>/dev/null
    
    if [ $? -eq 0 ]; then
        echo "✓ 已设置 ${minutes} 分钟后提醒: $title"
        echo "  任务ID: $id"
    else
        # at 失败，改用 cron（每分钟检查）
        echo "*/1 * * * * [ -f \"$script\" ] && \"$script\" $CRON_TAG" | crontab -
        echo "✓ 已设置 ${minutes} 分钟后提醒: $title (使用 cron)"
        echo "  任务ID: $id"
    fi
}

# 添加周期性任务
add_recurring() {
    local schedule="$1"  # 如 "0 23 * * *"
    local title="$2"
    local content="${3:-$2}"
    local id=$(generate_id)
    
    # 添加到 crontab
    (crontab -l 2>/dev/null || echo "") > /tmp/crontab.tmp
    echo "$schedule /opt/feishu-notifier/bin/notify '$title' '$content' $CRON_TAG $id" >> /tmp/crontab.tmp
    crontab /tmp/crontab.tmp
    rm /tmp/crontab.tmp
    
    echo "✓ 已添加周期性提醒: $title"
    echo "  调度: $schedule"
    echo "  任务ID: $id"
}

# 列出任务
list() {
    echo "=== 一次性任务 ==="
    atq 2>/dev/null | head -10
    
    echo ""
    echo "=== 周期性任务 ==="
    crontab -l 2>/dev/null | grep "$CRON_TAG" | nl
}

# 删除周期性任务
remove() {
    local id="$1"
    (crontab -l 2>/dev/null | grep -v "$id") | crontab -
    echo "✓ 已删除任务 $id"
}

# 帮助
help() {
    cat << 'EOF'
用法: feishu-relay-task <命令> [参数]

命令:
  once <分钟> <标题> [内容]     一次性提醒（N分钟后）
  daily <HH:MM> <标题> [内容]   每日提醒
  weekly <时间> <标题> [内容]   每周提醒
  list                          列出所有任务
  remove <ID>                   删除周期性任务

示例:
  feishu-relay-task once 30 "该休息了"
  feishu-relay-task daily 23:00 "睡觉"
  feishu-relay-task list

EOF
}

# 主逻辑
init

case "$1" in
    once)
        add_once "$2" "$3" "$4"
        ;;
    daily)
        hour=$(echo "$2" | cut -d: -f1)
        min=$(echo "$2" | cut -d: -f2)
        add_recurring "$min $hour * * *" "$3" "$4"
        ;;
    weekly)
        hour=$(echo "$2" | cut -d: -f1)
        min=$(echo "$2" | cut -d: -f2)
        add_recurring "$min $hour * * 1" "$3" "$4"
        ;;
    list)
        list
        ;;
    remove)
        remove "$2"
        ;;
    *)
        help
        ;;
esac
