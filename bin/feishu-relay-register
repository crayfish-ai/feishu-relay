#!/bin/bash
#
# feishu-relay-register - 手动注册/注销系统到 Feishu Relay
# 用法: feishu-relay-register [register|unregister|list|status] [name] [type] [path]
#

set -e

REGISTRY_FILE="/opt/feishu-notifier/registry/systems.json"
NOTIFY_BIN="/opt/feishu-notifier/bin/notify"

# 颜色输出
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

log_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

log_success() {
    echo -e "${GREEN}[OK]${NC} $1"
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# 确保注册表文件存在
init_registry() {
    if [[ ! -f "$REGISTRY_FILE" ]]; then
        mkdir -p "$(dirname "$REGISTRY_FILE")"
        echo '{"systems": [], "updated_at": ""}' > "$REGISTRY_FILE"
        log_info "Created new registry file"
    fi
}

# 生成系统 ID
generate_id() {
    echo -n "$1" | md5sum | cut -c1-8
}

# 注册系统
cmd_register() {
    local name="$1"
    local type="${2:-service}"
    local path="${3:-$(pwd)}"
    
    if [[ -z "$name" ]]; then
        log_error "Usage: feishu-relay-register register <name> [type] [path]"
        log_info "Types: website, service, skill, task, data"
        exit 1
    fi
    
    # 标准化路径
    path="$(realpath "$path" 2>/dev/null || echo "$path")"
    
    init_registry
    
    # 检查是否已存在
    if jq -e ".systems[] | select(.name == \"$name\")" "$REGISTRY_FILE" &>/dev/null; then
        log_warn "System '$name' already registered, updating..."
        # 删除旧记录
        jq "del(.systems[] | select(.name == \"$name\"))" "$REGISTRY_FILE" > "${REGISTRY_FILE}.tmp"
        mv "${REGISTRY_FILE}.tmp" "$REGISTRY_FILE"
    fi
    
    # 添加新记录
    local id=$(generate_id "$path")
    local timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
    
    jq ".systems += [{
        \"id\": \"$id\",
        \"name\": \"$name\",
        \"type\": \"$type\",
        \"path\": \"$path\",
        \"notify_method\": \"auto\",
        \"registered_at\": \"$timestamp\",
        \"status\": \"active\",
        \"auto_discovered\": false
    }] | .updated_at = \"$timestamp\"" "$REGISTRY_FILE" > "${REGISTRY_FILE}.tmp"
    mv "${REGISTRY_FILE}.tmp" "$REGISTRY_FILE"
    
    log_success "Registered: $name ($type)"
    log_info "Path: $path"
    
    # 发送通知
    if [[ -x "$NOTIFY_BIN" ]]; then
        $NOTIFY_BIN "🆕 系统已注册" "名称: $name\n类型: $type\n路径: $path" 2>/dev/null || true
    fi
}

# 注销系统
cmd_unregister() {
    local name="$1"
    
    if [[ -z "$name" ]]; then
        log_error "Usage: feishu-relay-register unregister <name>"
        exit 1
    fi
    
    if [[ ! -f "$REGISTRY_FILE" ]]; then
        log_error "Registry file not found"
        exit 1
    fi
    
    if ! jq -e ".systems[] | select(.name == \"$name\")" "$REGISTRY_FILE" &>/dev/null; then
        log_error "System '$name' not found in registry"
        exit 1
    fi
    
    jq "del(.systems[] | select(.name == \"$name\"))" "$REGISTRY_FILE" > "${REGISTRY_FILE}.tmp"
    mv "${REGISTRY_FILE}.tmp" "$REGISTRY_FILE"
    
    log_success "Unregistered: $name"
}

# 列出所有系统
cmd_list() {
    if [[ ! -f "$REGISTRY_FILE" ]]; then
        log_info "No systems registered yet"
        return
    fi
    
    local count=$(jq '.systems | length' "$REGISTRY_FILE")
    
    echo ""
    echo "Registered Systems ($count total):"
    echo "────────────────────────────────────────────────────────────"
    printf "%-15s %-10s %-12s %-20s\n" "NAME" "TYPE" "STATUS" "PATH"
    echo "────────────────────────────────────────────────────────────"
    
    jq -r '.systems[] | [.name, .type, .status, .path] | @tsv' "$REGISTRY_FILE" | \
    while IFS=$'\t' read -r name type status path; do
        printf "%-15s %-10s %-12s %-20s\n" "$name" "$type" "$status" "${path:0:35}"
    done
    
    echo "────────────────────────────────────────────────────────────"
}

# 显示系统详情
cmd_status() {
    local name="$1"
    
    if [[ -z "$name" ]]; then
        # 显示整体状态
        if [[ ! -f "$REGISTRY_FILE" ]]; then
            log_info "No registry found"
            return
        fi
        
        local total=$(jq '.systems | length' "$REGISTRY_FILE")
        local active=$(jq '[.systems[] | select(.status == "active")] | length' "$REGISTRY_FILE")
        local auto=$(jq '[.systems[] | select(.auto_discovered == true)] | length' "$REGISTRY_FILE")
        local manual=$((total - auto))
        
        echo ""
        echo "Feishu Relay Registry Status"
        echo "────────────────────────────────"
        echo "Total systems:    $total"
        echo "Active:           $active"
        echo "Auto-discovered:  $auto"
        echo "Manually added:   $manual"
        echo "Registry file:    $REGISTRY_FILE"
        echo "────────────────────────────────"
    else
        # 显示特定系统详情
        if ! jq -e ".systems[] | select(.name == \"$name\")" "$REGISTRY_FILE" &>/dev/null; then
            log_error "System '$name' not found"
            exit 1
        fi
        
        echo ""
        echo "System Details: $name"
        echo "────────────────────────────────"
        jq ".systems[] | select(.name == \"$name\")" "$REGISTRY_FILE"
        echo "────────────────────────────────"
    fi
}

# 发送测试通知
cmd_notify() {
    local name="$1"
    local message="${2:-Test notification}"
    
    if [[ -z "$name" ]]; then
        log_error "Usage: feishu-relay-register notify <name> [message]"
        exit 1
    fi
    
    if [[ ! -f "$REGISTRY_FILE" ]]; then
        log_error "Registry file not found"
        exit 1
    fi
    
    if ! jq -e ".systems[] | select(.name == \"$name\")" "$REGISTRY_FILE" &>/dev/null; then
        log_error "System '$name' not found"
        exit 1
    fi
    
    local type=$(jq -r ".systems[] | select(.name == \"$name\") | .type" "$REGISTRY_FILE")
    
    if [[ -x "$NOTIFY_BIN" ]]; then
        $NOTIFY_BIN "[$name] $type" "$message"
        log_success "Notification sent for $name"
    else
        log_error "Notify binary not found: $NOTIFY_BIN"
        exit 1
    fi
}

# 触发手动扫描
cmd_scan() {
    log_info "Triggering manual discovery scan..."
    
    if [[ -f "/opt/feishu-notifier/lib/feishu-relay-auto-discovery.py" ]]; then
        python3 /opt/feishu-notifier/lib/feishu-relay-auto-discovery.py
    else
        log_error "Auto discovery script not found"
        exit 1
    fi
}

# 显示帮助
cmd_help() {
    cat << 'EOF'
Feishu Relay System Registration

USAGE:
    feishu-relay-register <command> [options]

COMMANDS:
    register <name> [type] [path]   Register a new system
    unregister <name>               Remove a system from registry
    list                            List all registered systems
    status [name]                   Show status (all or specific system)
    notify <name> [message]         Send test notification
    scan                            Trigger manual discovery scan
    help                            Show this help message

EXAMPLES:
    # Register a website
    feishu-relay-register register myapp website /var/www/myapp

    # Register current directory as a service
    feishu-relay-register register myapi service

    # List all systems
    feishu-relay-register list

    # Send test notification
    feishu-relay-register notify myapp "Deployment successful"

    # Trigger discovery scan
    feishu-relay-register scan

SYSTEM TYPES:
    website    - Web applications (HTML, PHP, Node.js, etc.)
    service    - Background services and APIs
    skill      - OpenClaw skills
    task       - Scheduled tasks and cron jobs
    data       - Data processing pipelines

EOF
}

# 主函数
main() {
    local cmd="${1:-help}"
    
    case "$cmd" in
        register)
            cmd_register "$2" "$3" "$4"
            ;;
        unregister|remove|delete)
            cmd_unregister "$2"
            ;;
        list|ls)
            cmd_list
            ;;
        status|info)
            cmd_status "$2"
            ;;
        notify|test)
            cmd_notify "$2" "$3"
            ;;
        scan|discover)
            cmd_scan
            ;;
        help|--help|-h)
            cmd_help
            ;;
        *)
            log_error "Unknown command: $cmd"
            cmd_help
            exit 1
            ;;
    esac
}

main "$@"
