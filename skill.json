{
  "name": "feishu-relay",
  "version": "2.1.0",
  "description": "统一飞书通知系统 - 可靠的消息队列和重试机制",
  "author": "crayfish-ai",
  "license": "MIT",
  "repository": "https://github.com/crayfish-ai/feishu-relay",
  "keywords": ["feishu", "lark", "notification", "queue", "relay"],
  "entry": "bin/notify",
  "config": {
    "FEISHU_APP_ID": {
      "type": "string",
      "description": "飞书应用 ID",
      "required": true
    },
    "FEISHU_APP_SECRET": {
      "type": "string",
      "description": "飞书应用密钥",
      "required": true,
      "sensitive": true
    },
    "FEISHU_USER_ID": {
      "type": "string",
      "description": "接收者 ID",
      "required": true
    },
    "FEISHU_RECEIVE_ID_TYPE": {
      "type": "string",
      "description": "ID 类型",
      "default": "open_id",
      "enum": ["open_id", "user_id", "chat_id", "email"]
    }
  }
}
